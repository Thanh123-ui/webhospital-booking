# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Sao chép file này thành .env và điền thông tin thực tế
# Không commit file .env vào Git!
# ─────────────────────────────────────────────────────────────────────────────

# Chế độ Database: "mock" (mặc định) hoặc "mysql"
DB_MODE=mock

# ── Chỉ cần điền khi DB_MODE=mysql ──────────────────────────────────────────
DB_HOST=your-rds-endpoint.amazonaws.com
DB_USER=admin
DB_PASSWORD=your_password_here
DB_NAME=hospital

# ── Port backend (tuỳ chọn) ──────────────────────────────────────────────────
PORT=5000
